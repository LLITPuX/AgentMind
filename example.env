# example.env (перейменуйте на .env)
# Скопіюйте цей файл у .env і замініть значення на свої.
# ЗАБОРОНЕНО: використовувати лапки, пробіли навколо знака "=", дефіси на початку.
# ПРАВИЛЬНО: OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# НЕПРАВИЛЬНО: OPENAI_API_KEY = "sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# --- Ключі API ---
# Ваш секретний ключ від OpenAI. Необхідний для роботи з моделями GPT.
OPENAI_API_KEY=sk-YourSecretAPIKeyGoesHere

# --- Налаштування підключення до FalkorDB ---
# Ці змінні в основному використовуються всередині Docker, але корисно мати їх для локального запуску.
# Хост, на якому запущено FalkorDB. У Docker-мережі це ім'я сервісу.
FALKORDB_HOST=falkordb

# Порт, який слухає FalkorDB.
FALKORDB_PORT=6379
